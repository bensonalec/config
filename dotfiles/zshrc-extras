# Sourced by the dev box's baked ~/.zshrc on every interactive shell.
# Anything that should persist across image rebuilds lives here.

# ---- Editor & pager ----
export EDITOR=nvim
export VISUAL=nvim
export PAGER=less
export LESS="-FRX"

# ---- mise trust (dev box uses symlinks; resolved paths differ from $HOME) ----
export MISE_TRUSTED_CONFIG_PATHS=/workspace/state/config/mise:/workspace/projects

# ---- Plugins (antidote is baked into the image at /opt/antidote) ----
source /opt/antidote/antidote.zsh
antidote load /workspace/dotfiles/zsh_plugins.txt

# ---- Completion ----
autoload -Uz compinit
if [[ -n ~/.zcompdump(#qN.mh+24) ]]; then
  compinit
else
  compinit -C
fi
zstyle ':completion:*' menu select
zstyle ':completion:*' matcher-list 'm:{a-zA-Z}={A-Za-z}'
zstyle ':completion:*' list-colors "${(s.:.)LS_COLORS}"
zstyle ':completion:*:descriptions' format '[%d]'
zstyle ':fzf-tab:complete:cd:*' fzf-preview 'ls --color=always $realpath'
zstyle ':fzf-tab:*' use-fzf-default-opts yes

# ---- Key bindings ----
bindkey -e
bindkey '^[[A' history-substring-search-up
bindkey '^[[B' history-substring-search-down
bindkey '^P'   history-substring-search-up
bindkey '^N'   history-substring-search-down

# ---- Shell behavior ----
setopt AUTO_CD AUTO_PUSHD PUSHD_IGNORE_DUPS EXTENDED_GLOB \
       INTERACTIVE_COMMENTS NO_BEEP CORRECT

# ---- Aliases ----
alias ll='ls -lah --color=auto'
alias la='ls -A --color=auto'
alias l='ls -CF --color=auto'

alias gs='git status'
alias gd='git diff'
alias gds='git diff --staged'
alias gco='git checkout'
alias gcm='git commit -m'
alias gp='git push'
alias gl='git pull'
alias glog='git log --oneline --graph --decorate'

alias ws='cd /workspace/projects'
alias ffe='cd /workspace/projects/ff_elixir'

alias mps='mix phx.server'
alias iexs='iex -S mix'
alias mt='mix test'

alias mi='mise install'
alias mu='mise use'
alias mls='mise ls'

alias gor='go run .'
alias got='go test ./...'

alias fl='fly'
alias fll='fly logs'
alias fls='fly ssh console'

alias k='kubectl'
alias tf='terraform'
alias dc='docker compose'

alias vscode-sync='/workspace/dotfiles/install-vscode-extensions.sh'
alias reload='exec zsh'

# ---- fzf integration ----
[ -f /usr/share/doc/fzf/examples/key-bindings.zsh ] && \
  source /usr/share/doc/fzf/examples/key-bindings.zsh
[ -f /usr/share/doc/fzf/examples/completion.zsh ] && \
  source /usr/share/doc/fzf/examples/completion.zsh

export FZF_DEFAULT_OPTS="--height 40% --layout=reverse --border --info=inline"
export FZF_DEFAULT_COMMAND='fdfind --type f --hidden --follow --exclude .git'
export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"

# ---- Tool completions ----
command -v gh  >/dev/null && eval "$(gh completion -s zsh)"
command -v fly >/dev/null && eval "$(fly completion zsh)"
command -v kubectl >/dev/null && source <(kubectl completion zsh)

# ---- Prompt (starship is baked into the image) ----
eval "$(starship init zsh)"

# ---- Local-only overrides (gitignored: API keys, machine-specific) ----
[ -f /workspace/dotfiles/zshrc-local ] && source /workspace/dotfiles/zshrc-local